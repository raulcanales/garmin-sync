# User 1 (required). Legacy names GARMIN_EMAIL / GARMIN_PASSWORD still work.
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-garmin-password
# GARMIN_USER_1_ID=user1

# User 2 (optional — omit both vars to run single-user)
# GARMIN_USER_2_EMAIL=partner@example.com
# GARMIN_USER_2_PASSWORD=their-garmin-password
# GARMIN_USER_2_ID=user2

# Local stack (docker compose --profile local up) uses bundled Postgres by default.
# DATABASE_URL=postgresql://garmin:garmin@postgres:5432/garmin

# Unraid / external Postgres — set this and run without --profile local:
# DATABASE_URL=postgresql://user:pass@your-db-host:5432/yourdb

# GARMIN_DATA_DIR=./data
