          "rawQuery": true,
          "rawSql": "SELECT started_at AS time,\n  CASE WHEN status IN ('success', 'partial') THEN 1 ELSE 0 END AS value\nFROM garmin.v_sync_log\nWHERE nickname = ${user:singlequote}\nORDER BY started_at DESC\nLIMIT 1",
